# Local DB configuration — copy to .env.local and adjust as needed.
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=bikri_db
DB_USERNAME=root
DB_PASSWORD=

# Shared HMAC secret for JWT signing/verification across services.
# Leave unset to fall back to the in-repo dev default (see docker-compose.yml).
JWT_SECRET=

# Token TTLs. Leave unset for defaults: 3 hrs access / 7 days refresh.
JWT_ACCESS_TOKEN_TTL_MS=10800000
JWT_REFRESH_TOKEN_TTL_SEC=604800
BACKEND_HOST_PORT=8081

# DB+Redis session-store migration (replaces the Caffeine claims cache) — kill switch.
# false = identical behavior to before this migration (default).
# true  = writes auth_sessions rows + session:{jti} Redis keys on login/refresh, and runs
#         the shadow (log-only) revocation check in JwtAuthWebFilter. Does not change what
#         gets denied yet — see the migration plan for the cutover steps.
AUTH_SESSION_STORE_ENABLED=false
AUTH_SESSION_CLEANUP_CRON=0 0 2 * * *
AUTH_SESSION_CLEANUP_GRACE_HOURS=24
